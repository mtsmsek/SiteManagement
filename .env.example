# Copy this file to `.env` and tweak as needed. `.env` is gitignored.
# docker-compose reads this file automatically.

# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=sitemanagement
POSTGRES_PASSWORD=sitemanagement_dev_pw
POSTGRES_DB=sitemanagement
POSTGRES_PORT=5432

# -- MongoDB (used by PaymentService in W4) -----------------------------------
MONGO_ROOT_USER=mongoroot
MONGO_ROOT_PASSWORD=mongo_dev_pw
MONGO_PORT=27017

# -- MailHog (dev SMTP catcher) -----------------------------------------------
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# -- API ----------------------------------------------------------------------
API_PORT=8080

# -- JWT (used from W1 Day 4 onward) ------------------------------------------
# Generate a real secret for production. The dev value below is fine locally.
JWT_KEY=dev-only-secret-please-change-me-at-least-32-chars
JWT_ISSUER=SiteManagement
JWT_AUDIENCE=SiteManagement.Clients
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=14

# -- Bootstrap admin (W2 Day 5 onward) ----------------------------------------
# The API has no public registration endpoint by design. On startup, if the
# values below are set, the first admin account is created automatically.
# After it logs in once, every other user is created through authenticated
# admin endpoints. Leave blank to skip seeding (e.g. tests).
ADMIN_BOOTSTRAP_EMAIL=admin@sitemanagement.local
ADMIN_BOOTSTRAP_PASSWORD=Str0ng-P@ss-Dev
ADMIN_BOOTSTRAP_FULL_NAME=Site Admin

# -- CORS (W2 Day 6 onward) ---------------------------------------------------
# In Development the Angular dev server (http://localhost:4200) is always
# allowed. Set this for non-dev environments to whitelist your Angular
# deployment (e.g. https://app.sitemanagement.example.com).
CORS_ALLOWED_ORIGIN_0=
